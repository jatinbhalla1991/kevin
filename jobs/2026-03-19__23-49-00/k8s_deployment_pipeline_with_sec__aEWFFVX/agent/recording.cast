[10.350263, "o", "total 24\r\ndrwxr-xr-x 1 root root 4096 Mar 19 18:07 .\r\ndrwxr-xr-x 1 root root 4096 Mar 19 18:20 ..\r\n-rw-r--r-- 1 root root  207 Mar 19 18:06 Dockerfile\r\n-rw-r--r-- 1 root root  645 Mar 19 18:06 app.py\r\n-rw-r--r-- 1 root root  630 Mar 19 18:06 k8s-deployment.yaml\r\n-rw-r--r-- 1 root root   30 Mar 19 18:06 requirements.txt\r\n"]
