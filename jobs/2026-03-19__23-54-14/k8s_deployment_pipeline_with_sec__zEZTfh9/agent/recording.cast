[80.649157, "i", "cat > Dockerfile << 'EOF'\nFROM python:3.12-slim\n\nWORKDIR /app\n\n# Install system dependencies\nRUN apt-get update && apt-get install -y \\\n    gcc \\\n    && rm -rf /var/lib/apt/lists/*\n\n# Copy requirements first for better caching\nCOPY requirements.txt /app/\nRUN pip install --no-cache-dir -r requirements.txt\n\n# Copy application files\nCOPY . /app/\n\n# Create non-root user\nRUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app\nUSER appuser\n\n# Expose port\nEXPOSE 8080\n\n# Health check\nHEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \\\n    CMD python -c \"import requests; requests.get('http://localhost:8080/health')\" || exit 1\n\n# Run the application with gunicorn\nCMD [\"gunicorn\", \"--bind\", \"0.0.0.0:8080\", \"--workers\", \"4\", \"app:app\"]\nEOF\n"]
[80.653356, "o", "cat > Dockerfile << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> FROM python:3.12-slim\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> WORKDIR /app\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Install system dependencies\r\n\u001b[?2004l\r\u001b[?2004h> RUN apt-get update && apt-get install -y \\\r\n\u001b[?2004l\r\u001b[?2004h>     gcc \\\r\n\u001b[?2004l\r\u001b[?2004h>     && rm -rf /var/lib/apt/lists/*\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Copy requirements first for better caching\r\n\u001b[?2004l\r\u001b[?2004h> COPY requirements.txt /app/\r\n\u001b[?2004l\r\u001b[?2004h> RUN pip install --no-cache-dir -r requirements.txt\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Copy application files\r\n\u001b[?2004l\r\u001b[?2004h> COPY . /app/\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Create non-root user\r\n\u001b[?2004l\r\u001b[?2004h> RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app\r\n\u001b[?2004l\r\u001b[?2004h> USER appuser\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Expose port\r\n\u001b[?2004l\r\u001b[?2004h> EXPOSE 8080\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Health check\r\n\u001b[?2004l\r\u001b[?2004h"]
[80.653569, "o", "> "]
[80.65363, "o", "HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \\\r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.653759, "o", "    CMD python -c \"import requests; requests.get('http://localhost:8080/health')\" || exit 1\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.653915, "o", "# Run the application with gunicorn\r\n\u001b[?2004l\r\u001b[?2004h> "]
[80.654185, "o", "CMD [\"gunicorn\", \"--bind\", \"0.0.0.0:8080\", \"--workers\", \"4\", \"app:app\"]\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
