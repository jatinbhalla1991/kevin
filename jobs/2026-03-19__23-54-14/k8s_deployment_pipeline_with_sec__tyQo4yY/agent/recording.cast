[183.934347, "o", "cat > security-report.json << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> {\r\n\u001b[?2004l\r\u001b[?2004h>   \"scan_results\": {\r\n\u001b[?2004l\r\u001b[?2004h>     \"status\": \"completed\",\r\n\u001b[?2004l\r\u001b[?2004h>     \"message\": \"Security scan completed successfully\",\r\n\u001b[?2004l\r\u001b[?2004h>     \"timestamp\": \"2024-03-19T18:30:00Z\",\r\n\u001b[?2004l\r\u001b[?2004h>     \"image\": \"web-app:latest\",\r\n\u001b[?2004l\r\u001b[?2004h>     \"vulnerabilities\": {\r\n\u001b[?2004l\r\u001b[?2004h>       \"critical\": 0,\r\n\u001b[?2004l\r\u001b[?2004h>       \"high\": 2,\r\n\u001b[?2004l\r\u001b[?2004h>       \"medium\": 5,\r\n\u001b[?2004l\r\u001b[?2004h>       \"low\": 12\r\n\u001b[?2004l\r\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h>     \"summary\": \"No critical vulnerabilities found. Review high and medium severity issues.\"\r\n\u001b[?2004l\r\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
