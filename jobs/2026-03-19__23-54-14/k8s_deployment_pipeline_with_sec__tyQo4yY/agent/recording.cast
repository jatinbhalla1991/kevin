[148.702979, "i", "cat > deploy.sh << 'EOF'\n#!/bin/bash\n\n# Deployment Pipeline Script\n# This script orchestrates the complete deployment pipeline\n\nset -e  # Exit on any error\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nIMAGE_NAME=\"web-app\"\nIMAGE_TAG=\"latest\"\nFULL_IMAGE_NAME=\"${IMAGE_NAME}:${IMAGE_TAG}\"\nSECURITY_REPORT=\"${SCRIPT_DIR}/security-report.json\"\nDEPLOYMENT_SUMMARY=\"${SCRIPT_DIR}/deployment-summary.txt\"\n\necho \"Starting deployment pipeline...\"\n\n# Step 1: Build Docker image\necho \"Building Docker image: ${FULL_IMAGE_NAME}\"\nif ! command -v docker &> /dev/null; then\n    echo \"ERROR: Docker is not installed or not in PATH\"\n    exit 1\nfi\n\ndocker build -t \"${FULL_IMAGE_NAME}\" \"${SCRIPT_DIR}\"\nif [ $? -ne 0 ]; then\n    echo \"ERROR: Docker build failed\"\n    exit 1\nfi\necho \"Docker image built successfully\"\n\n# Step 2: Security scanning\necho \"Running security vulnerability scan...\"\nif command -v trivy &> /dev/null; then\n    echo \"Using Trivy for security scanning...\"\n    trivy image --format json --output \"${SECURITY_REPORT}\" \"${FULL_IMAGE_NAME}\"\nelif command -v docker &> /dev/null; then\n    echo \"Using Docker scan for security scanning...\"\n    docker scan --json \"${FULL_IMAGE_NAME}\" > \"${SECURITY_REPORT}\" 2>/dev/null || echo \"Docker scan not available or failed\"\nelse\n    echo \"WARNING: No security scanner available. Creating placeholder report.\"\n    cat > \"${SECURITY_REPORT}\" << 'SECURITY_EOF'\n{\n  \"scan_results\": {\n    \"status\": \"scan_not_available\",\n    \"message\": \"No security scanner (Trivy, Docker scan) available in this environment\",\n    \"timestamp\": \"$(date -Iseconds)\",\n    \"image\": \"${FULL_IMAGE_NAME}\"\n  }\n}\nSECURITY_EOF\nfi\n\n# Step 3: Validate Kubernetes manifests\necho \"Validating Kubernetes manifests...\"\nif command -v kubectl &> /dev/null; then\n    echo \"Using kubectl to validate manifests...\"\n    kubectl apply --dry-run=client -f \"${SCRIPT_DIR}/k8s-deployment.yaml\"\n    if [ $? -ne 0 ]; then\n        echo \"ERROR: Kubernetes manifest validation failed\"\n        exit 1\n    fi\nelif command -v kubeval &> /dev/null; then\n    echo \"Using kubeval to validate manifests...\"\n    kubeval \"${SCRIPT_DIR}/k8s-deployment.yaml\"\n    if [ $? -ne 0 ]; then\n        echo \"ERROR: Kubernetes manifest validation failed\"\n        exit 1\n    fi\nelse\n    echo \"WARNING: No Kubernetes validator available. Basic YAML validation only.\"\n    python3 -c \"import yaml; yaml.safe_load(open('${SCRIPT_DIR}/k8s-deployment.yaml'))\" || {\n        echo \"ERROR: Invalid YAML in Kubernetes manifest\"\n        exit 1\n    }\nfi\n\n# Step 4: Generate deployment summary\necho \"Generating deployment summary...\"\ncat > \"${DEPLOYMENT_SUMMARY}\" << SUMMARY_EOF\nDeployment Pipeline Summary\n==========================\nGenerated on: $(date)\nImage: ${FULL_IMAGE_NAME}\n\nApplication Status:\n- Flask web application configured for container deployment\n- Listening on port 8080\n- Health check endpoints: /health, /ready\n\nDocker Image:\n- Base image: python:3.12-slim\n- Application server: gunicorn with 3 workers\n- Port exposed: 8080\n\nSecurity Scanning:\n- Scan results saved to: ${SECURITY_REPORT}\n- Review the security report for any critical vulnerabilities\n\nKubernetes Configuration:\n- Deployment name: web-app\n- Replicas: 2\n- Service type: ClusterIP\n- Container port: 8080\n- Service port: 80\n- Health checks: Liveness and readiness probes configured\n- Resource limits: Memory 256Mi, CPU 200m\n- Resource requests: Memory 128Mi, CPU 100m\n\nNext Steps:\n1. Review security report: ${SECURITY_REPORT}\n2. Push image to registry if needed\n3. Deploy to Kubernetes: kubectl apply -f k8s-deployment.yaml\n4. Verify deployment: kubectl get pods -l app=web-app\n\nFiles Generated:\n- ${SECURITY_REPORT}\n- ${DEPLOYMENT_SUMMARY}\nSUMMARY_EOF\n\necho \"Deployment pipeline completed successfully!\"\necho \"Check ${DEPLOYMENT_SUMMARY} for details\"\necho \"Check ${SECURITY_REPORT} for security scan results\"\nEOF\n"]
[148.705869, "o", "cat > deploy.sh << 'EOF'\r\n\u001b[?2004l\r"]
[148.70811, "o", "\u001b[?2004h> #!/bin/bash\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Deployment Pipeline Script\r\n\u001b[?2004l\r\u001b[?2004h> # This script orchestrates the complete deployment pipeline\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> set -e  # Exit on any error\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\r\n\u001b[?2004l\r\u001b[?2004h> IMAGE_NAME=\"web-app\"\r\n\u001b[?2004l\r\u001b[?2004h> IMAGE_TAG=\"latest\"\r\n\u001b[?2004l\r\u001b[?2004h> FULL_IMAGE_NAME=\"${IMAGE_NAME}:${IMAGE_TAG}\"\r\n\u001b[?2004l\r\u001b[?2004h> SECURITY_REPORT=\"${SCRIPT_DIR}/security-report.json\"\r\n\u001b[?2004l\r\u001b[?2004h> DEPLOYMENT_SUMMARY=\"${SCRIPT_DIR}/deployment-summary.txt\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> echo \"Starting deployment pipeline...\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Step 1: Build Docker image\r\n\u001b[?2004l\r\u001b[?2004h> echo \"Building Docker image: ${FULL_IMAGE_NAME}\"\r\n\u001b[?2004l\r\u001b[?2004h> if ! command -v docker &> /dev/null; then\r\n\u001b[?2004l\r\u001b[?2004h>     echo \"ERROR: Docker is not installed or not in PATH\"\r\n\u001b[?2004l\r\u001b[?2004h>     exit 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[148.708791, "o", "> fi\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.708824, "o", "docker build -t \"${FULL_IMAGE_NAME}\" \"${SCRIPT_DIR}\"\r\n"]
[148.709473, "o", "\u001b[?2004l\r\u001b[?2004h> if [ $? -ne 0 ]; then\r\n\u001b[?2004l\r\u001b[?2004h>     echo \"ERROR: Docker build failed\"\r\n\u001b[?2004l\r\u001b[?2004h>     exit 1\r\n\u001b[?2004l\r\u001b[?2004h> fi\r\n\u001b[?2004l\r\u001b[?2004h> echo \"Docker image built successfully\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[148.709559, "o", "> "]
[148.709592, "o", "# Step 2: Security scanning\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.709861, "o", "echo \"Running security vulnerability scan...\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.70993, "o", "if command -v trivy &> /dev/null; then\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.710094, "o", "    echo \"Using Trivy for security scanning...\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.710256, "o", "    trivy image --format json --output \"${SECURITY_REPORT}\" \"${FULL_IMAGE_NAME}\"\r\n\u001b[?2004l\r\u001b[?2004h> elif command -v docker &> /dev/null; then\r\n\u001b[?2004l\r"]
[148.710447, "o", "\u001b[?2004h> "]
[148.710482, "o", "    echo \"Using Docker scan for security scanning...\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.710717, "o", "    docker scan --json \"${FULL_IMAGE_NAME}\" > \"${SECURITY_REPORT}\" 2>/dev/null || echo \"Docker scan not available or failed\"\r\n\u001b[?2004l\r\u001b[?2004h> else\r\n"]
[148.71074, "o", "\u001b[?2004l\r"]
[148.710936, "o", "\u001b[?2004h>     echo \"WARNING: No security scanner available. Creating placeholder report.\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[148.711078, "o", ">     cat > \"${SECURITY_REPORT}\" << 'SECURITY_EOF'\r\n\u001b[?2004l\r\u001b[?2004h> {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.711184, "o", "  \"scan_results\": {\r\n\u001b[?2004l\r\u001b[?2004h>     \"status\": \"scan_not_available\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[148.711352, "o", "> "]
[148.711467, "o", "    \"message\": \"No security scanner (Trivy, Docker scan) available in this environment\",\r\n\u001b[?2004l\r\u001b[?2004h>     \"timestamp\": \"$(date -Iseconds)\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.711479, "o", "    \"image\": \"${FULL_IMAGE_NAME}\"\r\n\u001b[?2004l\r\u001b[?2004h>   }\r\n\u001b[?2004l\r"]
[148.711854, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r\u001b[?2004h> SECURITY_EOF\r\n\u001b[?2004l\r\u001b[?2004h"]
[148.711969, "o", "> "]
[148.712045, "o", "fi\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # Step 3: Validate Kubernetes manifests\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.712215, "o", "echo \"Validating Kubernetes manifests...\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.71226, "o", "if command -v kubectl &> /dev/null; then\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.712411, "o", "    echo \"Using kubectl to validate manifests...\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.712447, "o", "    kubectl apply --dry-run=client -f \"${SCRIPT_DIR}/k8s-deployment.yaml\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.712674, "o", "    if [ $? -ne 0 ]; then\r\n\u001b[?2004l\r\u001b[?2004h>         echo \"ERROR: Kubernetes manifest validation failed\"\r\n\u001b[?2004l\r\u001b[?2004h>         exit 1\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.712707, "o", "    fi\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.712822, "o", "elif command -v kubeval &> /dev/null; then\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.71284, "o", "    echo \"Using kubeval to validate manifests...\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.713015, "o", "    kubeval \"${SCRIPT_DIR}/k8s-deployment.yaml\"\r\n\u001b[?2004l\r\u001b[?2004h>     if [ $? -ne 0 ]; then\r\n\u001b[?2004l\r\u001b[?2004h"]
[148.713041, "o", "> "]
[148.713186, "o", "        echo \"ERROR: Kubernetes manifest validation failed\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[148.713208, "o", "> "]
[148.713423, "o", "        exit 1\r\n\u001b[?2004l\r\u001b[?2004h>     fi\r\n\u001b[?2004l\r\u001b[?2004h> else\r\n\u001b[?2004l\r\u001b[?2004h>     echo \"WARNING: No Kubernetes validator available. Basic YAML validation only.\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[148.713596, "o", "> "]
[148.713698, "o", "    python3 -c \"import yaml; yaml.safe_load(open('${SCRIPT_DIR}/k8s-deployment.yaml'))\" || {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.713822, "o", "        echo \"ERROR: Invalid YAML in Kubernetes manifest\"\r\n\u001b[?2004l\r\u001b[?2004h>         exit 1\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> fi\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.714139, "o", "# Step 4: Generate deployment summary\r\n\u001b[?2004l\r\u001b[?2004h> echo \"Generating deployment summary...\"\r\n\u001b[?2004l\r\u001b[?2004h> cat > \"${DEPLOYMENT_SUMMARY}\" << SUMMARY_EOF\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.714349, "o", "Deployment Pipeline Summary\r\n\u001b[?2004l\r\u001b[?2004h> ==========================\r\n\u001b[?2004l\r\u001b[?2004h"]
[148.714381, "o", "> Generated on: $(date)\r\n\u001b[?2004l\r\u001b[?2004h> Image: ${FULL_IMAGE_NAME}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[148.714602, "o", "\u001b[?2004h> Application Status:\r\n\u001b[?2004l\r\u001b[?2004h> - Flask web application configured for container deployment\r\n\u001b[?2004l\r\u001b[?2004h"]
[148.7148, "o", "> - Listening on port 8080\r\n\u001b[?2004l\r\u001b[?2004h> - Health check endpoints: /health, /ready\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> Docker Image:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.715756, "o", "- Base image: python:3.12-slim\r\n\u001b[?2004l\r\u001b[?2004h> - Application server: gunicorn with 3 workers\r\n\u001b[?2004l\r\u001b[?2004h> - Port exposed: 8080\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> Security Scanning:\r\n\u001b[?2004l\r\u001b[?2004h> - Scan results saved to: ${SECURITY_REPORT}\r\n\u001b[?2004l\r\u001b[?2004h> - Review the security report for any critical vulnerabilities\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> Kubernetes Configuration:\r\n\u001b[?2004l\r\u001b[?2004h> - Deployment name: web-app\r\n\u001b[?2004l\r\u001b[?2004h> - Replicas: 2\r\n\u001b[?2004l\r\u001b[?2004h> - Service type: ClusterIP\r\n\u001b[?2004l\r\u001b[?2004h> - Container port: 8080\r\n\u001b[?2004l\r\u001b[?2004h> - Service port: 80\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.715929, "o", "- Health checks: Liveness and readiness probes configured\r\n\u001b[?2004l\r\u001b[?2004h> - Resource limits: Memory 256Mi, CPU 200m\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.716184, "o", "- Resource requests: Memory 128Mi, CPU 100m\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> Next Steps:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.716354, "o", "1. Review security report: ${SECURITY_REPORT}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.71638, "o", "2. Push image to registry if needed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.716604, "o", "3. Deploy to Kubernetes: kubectl apply -f k8s-deployment.yaml\r\n\u001b[?2004l\r\u001b[?2004h> 4. Verify deployment: kubectl get pods -l app=web-app\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> Files Generated:\r\n\u001b[?2004l\r\u001b[?2004h> - ${SECURITY_REPORT}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.716797, "o", "- ${DEPLOYMENT_SUMMARY}\r\n\u001b[?2004l\r\u001b[?2004h> SUMMARY_EOF\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> echo \"Deployment pipeline completed successfully!\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.716824, "o", "echo \"Check ${DEPLOYMENT_SUMMARY} for details\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[148.717019, "o", "echo \"Check ${SECURITY_REPORT} for security scan results\"\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[148.719001, "o", "\u001b[?2004hroot@7c616623bfa1:/app# "]
[168.4882, "i", "chmod +x deploy.sh\n"]
[168.488534, "o", "chmod +x deploy.sh\r\n\u001b[?2004l\r"]
